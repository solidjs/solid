{
  "$schema": "https://turborepo.org/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build", "^types"],
      "outputLogs": "new-only"
    },
    "@solidjs/signals#build": {
      "outputs": ["dist/**"]
    },
    "@solidjs/signals#types": {
      "outputs": ["dist/types/**", "dist/types-cjs/**"]
    },
    "solid-js#build": {
      "dependsOn": ["@solidjs/signals#build", "@solidjs/signals#types"],
      "outputs": ["dist/**", "**/dist/**"]
    },
    "solid-js#types": {
      "dependsOn": ["@solidjs/signals#types", "@solidjs/signals#build"],
      "outputs": ["types/**", "types-cjs/**", "**/types/**", "**/types-cjs/**"]
    },
    "@solidjs/web#link": {
      "dependsOn": ["solid-js#build"],
      "outputs": []
    },
    "@solidjs/web#build": {
      "dependsOn": ["solid-js#types", "@solidjs/web#link"],
      "outputs": ["dist/**", "**/dist/**"]
    },
    "@solidjs/h#link": {
      "dependsOn": ["@solidjs/web#build"],
      "outputs": []
    },
    "@solidjs/h#build": {
      "dependsOn": ["@solidjs/web#types", "@solidjs/h#link"],
      "outputs": ["dist/**", "**/dist/**"]
    },
    "@solidjs/element#build": {
      "dependsOn": ["solid-js#types", "@solidjs/web#types"]
    },
    "types": {
      "dependsOn": ["^types"],
      "outputs": ["types/**", "types-cjs/**", "dist/types-cjs/**", "**/types/**", "**/types-cjs/**", "**/dist/types-cjs/**"]
    },
    "@solidjs/web#types": {
      "dependsOn": ["^types"],
      "outputs": ["types/**", "types-cjs/**", "**/types/**", "**/types-cjs/**"]
    },
    "coverage": {
      "outputs": ["coverage/**"]
    },
    "test": {
      "outputs": []
    },
    "solid-js#test": {
      "dependsOn": ["@solidjs/signals#build"],
      "outputs": []
    },
    "@solidjs/web#test": {
      "dependsOn": ["solid-js#build", "@solidjs/web#build"],
      "outputs": []
    },
    "test-integration#test": {
      "dependsOn": [
        "@solidjs/signals#build",
        "solid-js#build",
        "@solidjs/web#build",
        "@solidjs/h#build",
        "@solidjs/html#build",
        "@solidjs/universal#build"
      ]
    },
    "solid-js#test-types": {
      "outputs": [],
      "dependsOn": ["types"]
    }
  }
}
