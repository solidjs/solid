{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "lib": ["ESNext", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "preserve",
    "jsxImportSource": "@solidjs/web",
    "esModuleInterop": true,
    "types": ["node"]
  },
  "include": [
    "shared/src/**/*",
    "stream/**/*.ts",
    "stream/**/*.tsx",
    "string/**/*.ts",
    "string/**/*.tsx",
    "csr/**/*.ts",
    "csr/**/*.tsx",
    "types.d.ts"
  ]
}
